NODE_ENV=production
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ai-report-agent?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-random-32-plus-character-secret
JWT_EXPIRES_IN=7d
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
CLIENT_URL=https://your-app.vercel.app
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_COLLECTION=report_documents
MAX_FILE_SIZE_MB=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-secure-admin-password
